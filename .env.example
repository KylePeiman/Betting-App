# TheOddsAPI — https://the-odds-api.com (free tier available)
ODDS_API_KEY=your_odds_api_key_here

# Betfair Exchange (optional — UK/EU accounts)
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERTS_PATH=

# SportsDataIO (optional)
SPORTSDATA_API_KEY=

# Anthropic (required for --mode agent)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (defaults to local SQLite)
DATABASE_URL=sqlite:///betting_app.db

# Claude model
CLAUDE_MODEL=claude-sonnet-4-6

# TheOddsAPI config
ODDS_API_REGIONS=us,uk,eu,au
ODDS_API_MARKETS=h2h,spreads,totals

# Engine config
MIN_EV_THRESHOLD=0.03
DEFAULT_SOURCES=odds_api

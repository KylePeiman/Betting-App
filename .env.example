# Kalshi prediction markets (https://kalshi.com/profile/api-keys)
# Create an API key on your Kalshi profile page, then download the private key PEM file.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem

# Optional: restrict categories (comma-separated, title-case). Leave blank to fetch all.
# Available: Crypto, Economics, Financials, Companies, Politics, Elections, Sports,
#            Climate and Weather, Entertainment, Science and Technology, World, Health
KALSHI_CATEGORIES=

# Polymarket (optional — not required for read-only market data / cross-arb scanning)
POLYMARKET_API_KEY=

# Anthropic (required for --mode agent only)
ANTHROPIC_API_KEY=

# Database (defaults to local SQLite — swap to Postgres via DATABASE_URL)
DATABASE_URL=sqlite:///betting_app.db

# Claude model for agent mode
CLAUDE_MODEL=claude-sonnet-4-6

# Minimum expected value threshold for the recommendation engine
MIN_EV_THRESHOLD=0.005

# Default data source
DEFAULT_SOURCES=kalshi
